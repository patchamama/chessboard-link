{
  "name": "chess-api-adapter-workspace",
  "private": true,
  "version": "0.7.2",
  "description": "Workspace for chess-board-link library and its web test app.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm --filter chess-board-link build",
    "build:lib": "pnpm --filter chess-board-link build",
    "build:app": "pnpm --filter @chess-board-link/web-test build",
    "test": "pnpm --filter chess-board-link test",
    "typecheck": "pnpm --filter chess-board-link typecheck && pnpm --filter @chess-board-link/web-test exec tsc --noEmit",
    "dev": "pnpm run build:lib && pnpm --filter @chess-board-link/web-test dev",
    "dev:app": "pnpm --filter @chess-board-link/web-test dev",
    "preview": "pnpm --filter @chess-board-link/web-test preview",
    "start": "pnpm run dev"
  }
}
