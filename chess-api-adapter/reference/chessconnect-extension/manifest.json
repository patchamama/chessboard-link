{
   "action": {
      "default_icon": "res/icon128up.png",
      "default_popup": "scripts/options/optiondlg.html",
      "default_title": "Chessconnect"
   },
   "background": {
      "service_worker": "dist/serviceworker.js"
   },
   "constants": {
      "isPhoenix": false
   },
   "content_scripts": [ {
      "js": [ "dist/chesscomcontent.js" ],
      "matches": [ "https://www.chess.com/*" ],
      "run_at": "document_idle",
      "world": "MAIN"
   }, {
      "js": [ "dist/chesscomhack.js" ],
      "matches": [ "https://www.chess.com/*" ],
      "run_at": "document_start",
      "world": "MAIN"
   }, {
      "js": [ "dist/lichesscontent.js" ],
      "matches": [ "https://lichess.org/*", "https://chessconnect.de/lichess*" ],
      "run_at": "document_idle",
      "world": "MAIN"
   }, {
      "js": [ "dist/lichesshack.js" ],
      "matches": [ "https://lichess.org/*", "https://www.maiachess.com/*" ],
      "run_at": "document_start",
      "world": "MAIN"
   }, {
      "js": [ "dist/noctieaicontent.js" ],
      "matches": [ "https://app.noctie.ai/*" ],
      "run_at": "document_idle",
      "world": "MAIN"
   }, {
      "js": [ "dist/chessiversecontent.js" ],
      "matches": [ "https://chessiverse.com/*" ],
      "run_at": "document_idle",
      "world": "MAIN"
   }, {
      "js": [ "dist/chessdojocontent.js" ],
      "matches": [ "https://www.chessdojo.club/*" ],
      "run_at": "document_idle",
      "world": "MAIN"
   }, {
      "js": [ "dist/chessablecontent.js" ],
      "matches": [ "https://www.chessable.com/*" ],
      "run_at": "document_idle",
      "world": "MAIN"
   }, {
      "js": [ "dist/maiachesscontent.js" ],
      "matches": [ "https://www.maiachess.com/*" ],
      "run_at": "document_idle",
      "world": "MAIN"
   }, {
      "js": [ "dist/chessmultimediacontent.js" ],
      "matches": [ "https://play.chessmultimedia.com/*" ],
      "run_at": "document_idle",
      "world": "MAIN"
   }, {
      "js": [ "dist/chessconnectcontent.js" ],
      "matches": [ "https://chessconnect.de/config-*" ],
      "run_at": "document_idle",
      "world": "MAIN"
   }, {
      "js": [ "dist/background.js" ],
      "matches": [ "https://www.chess.com/*", "https://lichess.org/*", "https://play.chessmultimedia.com/*", "https://chessconnect.de/config-*", "https://chessconnect.de/lichess*", "https://app.noctie.ai/*", "https://chessiverse.com/*", "https://www.chessdojo.club/*", "https://www.chessable.com/*", "https://www.maiachess.com/*" ],
      "run_at": "document_start",
      "world": "ISOLATED"
   } ],
   "default_locale": "en",
   "description": "__MSG_extensionDescription__",
   "icons": {
      "128": "res/icon128up.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "__MSG_extensionName__",
   "options_ui": {
      "open_in_tab": true,
      "page": "scripts/options/optionpage.html"
   },
   "permissions": [ "storage", "offscreen" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "6.0.3",
   "version_name": "6.0.3",
   "web_accessible_resources": [ {
      "matches": [ "https://www.chess.com/*", "https://lichess.org/*", "https://play.chessmultimedia.com/*", "https://chessconnect.de/*", "https://app.noctie.ai/*", "https://chessiverse.com/*", "https://www.chessdojo.club/*", "https://www.chessable.com/*", "https://www.maiachess.com/*" ],
      "resources": [ "res/beep.mp3", "res/knock.mp3", "res/pling.mp3", "res/icon128up.png", "res/icon128down.png", "res/icon128upred.png", "res/icon128downyellow.png", "res/icon128upgreen.png", "res/yesnodialog.html", "res/optionsdialog.html", "res/offscreen.html", "res/debugboard.html", "dist/offscreen.js", "res/GetItOnGooglePlay.png", "res/GetItOnAppStore.svg", "res/battery.png", "res/battery_board.png", "res/battery_pieces.png" ]
   } ]
}
